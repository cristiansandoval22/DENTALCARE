---
import "./TeamCard.css";

const { name, role, image } = Astro.props;
---

<!-- CARD -->
<article class="team-card">
  <div class="team-card__image">
    <img src={image} alt={name} />
  </div>

  <div class="team-card__content">
    <h3 class="team-card__name">{name}</h3>
    <p class="team-card__role">{role}</p>
  </div>
</article>
  